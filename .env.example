# Copy to .env (gitignored) for local `netlify dev` runs.
# In production, set the same vars in Netlify dashboard > Site > Env vars.

# Required: Google AI Studio key (https://aistudio.google.com/apikey).
# Free tier covers Gemini 2.5 Flash at 1,500 requests/day.
GEMINI_API_KEY=

# Optional: comma-separated list of allowed Referer prefixes for the
# /coach endpoint. Leave empty during local dev. In production, set to
# your Netlify URL, e.g. https://your-site.netlify.app
COACH_ALLOWED_ORIGINS=
